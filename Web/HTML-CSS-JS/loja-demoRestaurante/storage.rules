rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function usuario() {
      return request.auth != null
        ? firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data
        : null;
    }
    function ativo() { return usuario() != null && usuario().status == 'ativo'; }
    function admin() { return ativo() && usuario().tipo == 'admin'; }
    function lojistaDa(lojaId) { return ativo() && usuario().tipo == 'cliente' && usuario().lojaId == lojaId; }

    match /produtos/{lojaId}/{arquivo} {
      allow read: if true;
      allow write: if admin() || lojistaDa(lojaId);
    }
  }
}
